<?xml version="1.0"?>
<extension>
    <name>PLUGIN_CAPRICE</name>
    <module>Plugins::Caprice::Plugin</module>
    <version>{{ env['VERSION'] }}</version>
    <description>PLUGIN_CAPRICE_DESC</description>
    <icon>plugins/Caprice/Caprice_svg.png</icon>
    <defaultState>enabled</defaultState>
    <targetApplication>
        <id>SlimServer</id>
        <minVersion>7.9</minVersion>
        <maxVersion>*</maxVersion>
    </targetApplication>
    <optionsURL>plugins/Caprice/settings/basic.html</optionsURL>
    <creator>Xavier Raynaud, based on SomaFM plugin by Daniel Vijge</creator>
    <homepageURL>https://github.com/xraynaud/lms-caprice</homepageURL>
</extension>
